<body class="antialiased">
<!-- TopNavBar -->
<header class="fixed top-0 w-full z-50 bg-surface/70 backdrop-blur-[30px] border-b border-white/10 shadow-[0_20px_50px_rgba(195,192,255,0.1)]">
<nav class="flex justify-between items-center h-20 px-md md:px-xl max-w-container-max mx-auto">
<div class="font-headline-md text-headline-md font-bold tracking-tighter text-on-surface">ASTRIX</div>
<div class="hidden md:flex items-center gap-lg">
