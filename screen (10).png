<main>
<!-- Section 1: Hero Header -->
<section class="relative h-screen flex items-center justify-center overflow-hidden pt-20">

<div class="relative z-10 text-center px-md max-w-4xl">
<span class="font-label-md text-label-md text-primary tracking-[0.2em] mb-md block">ESTABLISHED 2018</span>
<h1 class="font-display-lg text-headline-lg md:text-display-lg text-white mb-md">
                    We Are Astrix. <br/>
<span class="text-gradient">We Build Excellence.</span>
</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
                    A boutique engineering collective dedicated to crafting elite digital experiences through precision code and high-performance design.
                </p>
</div>
<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
<span class="material-symbols-outlined text-primary text-3xl">expand_more</span>
</div>
</section>
<!-- Section 2: Mission -->
<section class="py-xl px-md max-w-container-max mx-auto">
<div class="flex flex-col md:flex-row gap-lg items-center">
