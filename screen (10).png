<style>
        body {
            background-color: #131313;
            color: #e5e2e1;
            overflow-x: hidden;
        }
        .glass-card {
            background: rgba(28, 27, 27, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .etched-border-b {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .text-gradient {
            background: linear-gradient(135deg, #c3c0ff 0%, #89ceff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .primary-button {
            background: linear-gradient(135deg, #4f46e5 0%, #00a2e6 100%);
            box-shadow: 0 0 20px rgba(195, 192, 255, 0.2);
            transition: all 0.3s ease;
        }
        .primary-button:hover {
            box-shadow: 0 0 30px rgba(195, 192, 255, 0.4);
            transform: scale(1.02);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
