<!-- Development Process Section -->
<section class="py-xl">
<div class="max-w-container-max mx-auto px-xl">
<h2 class="font-headline-lg text-headline-lg text-center mb-xl">Our Methodology</h2>
<div class="relative">
<!-- Timeline Line -->
<div class="absolute top-1/2 left-0 w-full h-[1px] bg-white/10 hidden lg:block transform -translate-y-1/2"></div>
<div class="grid grid-cols-1 lg:grid-cols-4 gap-lg relative z-10">
<!-- Step 1 -->
<div class="space-y-md text-center group">
<div class="w-16 h-16 rounded-full bg-surface-container-high border-4 border-surface border-t-primary flex items-center justify-center mx-auto relative group-hover:scale-110 transition-transform">
<span class="font-label-md text-primary">01</span>
</div>
<h4 class="font-headline-md text-[24px]">Discovery</h4>
<p class="font-body-md text-on-surface-variant px-md">Deep dive into your business goals, target audience, and technical requirements.</p>
</div>
<!-- Step 2 -->
<div class="space-y-md text-center group">
<div class="w-16 h-16 rounded-full bg-surface-container-high border-4 border-surface border-t-primary flex items-center justify-center mx-auto relative group-hover:scale-110 transition-transform">
<span class="font-label-md text-primary">02</span>
</div>
<h4 class="font-headline-md text-[24px]">Design</h4>
<p class="font-body-md text-on-surface-variant px-md">Crafting high-fidelity prototypes and technical blueprints with user-centric focus.</p>
</div>
<!-- Step 3 -->
<div class="space-y-md text-center group">
<div class="w-16 h-16 rounded-full bg-surface-container-high border-4 border-surface border-t-primary flex items-center justify-center mx-auto relative group-hover:scale-110 transition-transform">
<span class="font-label-md text-primary">03</span>
</div>
<h4 class="font-headline-md text-[24px]">Development</h4>
<p class="font-body-md text-on-surface-variant px-md">Agile execution with continuous delivery and rigorous automated testing.</p>
</div>
<!-- Step 4 -->
<div class="space-y-md text-center group">
<div class="w-16 h-16 rounded-full bg-surface-container-high border-4 border-surface border-t-primary flex items-center justify-center mx-auto relative group-hover:scale-110 transition-transform">
<span class="font-label-md text-primary">04</span>
